# App
APP_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Google OAuth
# IMPORTANT: Use a Google OAuth "Web application" client, not a desktop client.
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-web-client-secret

# Local example callback:
# http://localhost:3000/api/auth/callback/google
#
# Production example callback:
# https://your-vercel-app.vercel.app/api/auth/callback/google
#
# Add the exact deployed callback URL to Google Cloud > APIs & Services > Credentials.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Optional production persistence
# Add this in Vercel if you want persistent cached datasets across deployments.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token
